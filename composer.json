{
  "name": "besnovatyj/yii2-cms-themes",
  "description": "Модуль управления темами для Yii2 CMS",
  "version": "1.0.0",
  "type": "yii2-extension",
  "license": "MIT",
  "authors": [
    {
      "name": "Besnovatyj",
      "email": "your-email@example.com"
    }
  ],
  "minimum-stability": "stable",
  "extra": {
    "moduleClass": "Besnovatyj\\Themes\\Module",
    "moduleId": "Themes",
    "bescms": { "kind": "module" }
  },
  "keywords": [
    "yii2",
    "theme",
    "cms"
  ],
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "yiisoft/yii2-composer": true
    },
    "fxp-asset": {
      "enabled": false
    }
  },
  "require": {
    "php": ">=8.4",
    "yiisoft/yii2": "~2.0.0",
    "yiisoft/yii2-bootstrap5": "~2.0.0",
    "besnovatyj/yii2-cms-contracts": "^1.0",
    "besnovatyj/yii2-cms-helpers": "^1.0"
  },
  "require-dev": {
    "roave/security-advisories": "dev-latest"
  },
  "autoload": {
    "psr-4": {
      "Besnovatyj\\Themes\\": "src/"
    }
  }
}
